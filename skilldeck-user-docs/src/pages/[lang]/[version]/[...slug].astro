---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import VersionedLayout from '../../../layouts/VersionedLayout.astro';

// Supported languages and versions (can also be auto-detected)
const supportedLanguages = ['en', 'fr'];
const supportedVersions = ['v0.1', 'v0.2', 'latest'];

export const getStaticPaths = (async () => {
  const docs = await getCollection('docs');
  const paths = [];

  for (const doc of docs) {
    // doc.id format: "en/v0.1/getting-started/installation.md"
    const parts = doc.id.split('/');
    const lang = parts[0];
    const version = parts[1];
    const slug = parts.slice(2).join('/').replace(/\.mdx?$/, '');

    if (supportedLanguages.includes(lang) && supportedVersions.includes(version)) {
      paths.push({
        params: { lang, version, slug },
        props: { doc, type: 'page' },
      });
    }
  }

  // Generate index pages for each language/version
  for (const lang of supportedLanguages) {
    for (const version of supportedVersions) {
      paths.push({
        params: { lang, version, slug: undefined },
        props: { type: 'index' },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { lang, version, slug } = Astro.params;
const { doc, type } = Astro.props;

// Handle 404 (if slug provided but no doc)
if (slug && !doc) {
  return Astro.redirect(`/${lang}/${version}/404`);
}

// Prepare data for layout
const pageTitle = doc?.data?.title || `SkillDeck ${version} Documentation`;
const Content = doc ? (await doc.render()).Content : null;
---

<VersionedLayout
  lang={lang}
  version={version}
  title={pageTitle}
  content={Content}
  isIndex={type === 'index'}
/>
