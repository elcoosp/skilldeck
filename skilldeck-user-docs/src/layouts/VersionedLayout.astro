---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  lang: string;
  version: string;
  title: string;
  content: any;
  isIndex?: boolean;
}

const { lang, version, title, content, isIndex } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>{title} | SkillDeck Docs</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Add Starlight's default styles if needed, but rely on global CSS -->
  </head>
  <body>
    <Header />
    <div class="main-container">
      <Sidebar />
      <main class="content">
        {isIndex ? <h1>Welcome to SkillDeck {version}</h1> : <content />}
      </main>
    </div>
  </body>
</html>

<style>
  .main-container {
    display: flex;
    min-height: calc(100vh - var(--sl-nav-height));
  }
  .content {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }
</style>
