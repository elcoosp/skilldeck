---
export interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;

// Get current language and version from URL
const url = Astro.url;
const pathParts = url.pathname.split('/').filter(p => p);
const currentLang = pathParts[0] || 'en';
const currentVersion = pathParts[1] || 'latest';

// Build full URL by prepending language and version
// Remove leading slash if present to avoid double slash
const cleanHref = href.startsWith('/') ? href.substring(1) : href;
const fullHref = `/${currentLang}/${currentVersion}/${cleanHref}`;
---

<a href={fullHref} class={className}>
  <slot />
</a>
