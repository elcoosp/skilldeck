---
import { Icon } from '@astrojs/starlight/components';

export interface Props {
  question: string;
  onYes?: string;
  onNo?: string;
}

const { question, onYes, onNo } = Astro.props;
---

<div class="checkpoint" data-question={question} data-on-yes={onYes} data-on-no={onNo}>
  <p><Icon name="check-circle" /> <strong>Checkpoint:</strong> {question}</p>
  <div class="checkpoint-actions">
    <button class="checkpoint-yes">Yes</button>
    <button class="checkpoint-no">No</button>
  </div>
</div>

<script>
  document.querySelectorAll('.checkpoint').forEach(el => {
    const question = el.dataset.question;
    const onYes = el.dataset.onYes;
    const onNo = el.dataset.onNo;
    const yesBtn = el.querySelector('.checkpoint-yes');
    const noBtn = el.querySelector('.checkpoint-no');

    yesBtn?.addEventListener('click', () => {
      if (window.plausible) {
        window.plausible('Checkpoint', { props: { question, answer: 'yes' } });
      }
      if (onYes) {
        const msg = document.createElement('div');
        msg.className = 'checkpoint-feedback';
        msg.innerHTML = onYes;
        el.insertAdjacentElement('afterend', msg);
      }
      yesBtn.disabled = true;
      noBtn.disabled = true;
    });

    noBtn?.addEventListener('click', () => {
      if (window.plausible) {
        window.plausible('Checkpoint', { props: { question, answer: 'no' } });
      }
      if (onNo) {
        const msg = document.createElement('div');
        msg.className = 'checkpoint-feedback';
        msg.innerHTML = onNo;
        el.insertAdjacentElement('afterend', msg);
      }
      yesBtn.disabled = true;
      noBtn.disabled = true;
    });
  });
</script>

<style>
  .checkpoint {
    background: var(--sl-color-gray-6);
    border-radius: 0.5rem;
    padding: 1rem;
    margin: 1rem 0;
  }
  .checkpoint p {
    margin: 0 0 0.75rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .checkpoint p :global(svg) {
    width: 1.2em;
    height: 1.2em;
    color: var(--sl-color-accent);
  }
  .checkpoint-actions {
    display: flex;
    gap: 0.75rem;
  }
  .checkpoint button {
    padding: 0.5rem 0;         /* remove side padding */
    width: 80px;               /* fixed width */
    font-size: 0.9rem;
    font-weight: 500;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-gray-7);
    color: var(--sl-color-white);
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 0.1s ease;
    line-height: 1.5;
    text-align: center;
    box-sizing: border-box;    /* include padding and border in width */
  }
  .checkpoint button:hover {
    background: var(--sl-color-gray-5);
  }
  .checkpoint button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .checkpoint-feedback {
    margin-top: 1rem;
    padding: 0.75rem;
    background: var(--sl-color-gray-5);
    border-radius: 0.375rem;
    border-left: 3px solid var(--sl-color-accent);
  }
  :global(html[data-theme='dark']) .checkpoint button {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-1);
  }
  :global(html[data-theme='dark']) .checkpoint button:hover {
    background: var(--sl-color-gray-5);
  }
</style>
