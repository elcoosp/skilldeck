{
        "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
        "assist": {
                "actions": {
                        "source": {
                                "organizeImports": "on"
                        }
                }
        },
        "linter": {
                "enabled": true,
                "rules": {
                        "recommended": true,
                        "correctness": {
                                "noUnusedImports": "warn",
                                "noUnusedVariables": "warn"
                        },
                        "style": {
                                "noNonNullAssertion": "off"
                        },
                        "suspicious": {
                                "noExplicitAny": "warn"
                        }
                }
        },
        "formatter": {
                "enabled": true,
                "indentStyle": "tab",
                "lineWidth": 100
        },
        "javascript": {
                "formatter": {
                        "quoteStyle": "single",
                        "semicolons": "asNeeded",
                        "trailingCommas": "all"
                }
        },
        "files": {
                "includes": [
                        "**",
                        "!!**/node_modules",
                        "!!**/.next",
                        "!!**/dist",
                        "!!**/build",
                        "!!**/*.config.*"
                ]
        }
}
