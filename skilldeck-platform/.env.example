# SkillDeck Platform — environment variables
# Copy to .env and fill in real values.

# SQLite database path (for MVP; swap DATABASE_URL for postgres:// in production)
DATABASE_URL=sqlite:./platform.db

# TCP address to bind
LISTEN_ADDR=0.0.0.0:8080

# Resend API key for transactional email (optional — uses no-op if not set)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Base URL used in verification links and email footers
PLATFORM_URL=https://platform.skilldeck.dev

# From address for outbound email
FROM_EMAIL=noreply@skilldeck.dev
