  "bugs": {
    "url": "https://github.com/elcoosp/skilldeck/issues"
  },
  "homepage": "https://github.com/elcoosp/skilldeck#readme",
  "scripts": {
    "dev": "vite",
    "build": "lingui compile && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:icon": "tauri icon public/logo.svg",
    "tauri:build": "tauri build",
    "lint": "biome check .",
    "check": "tsc --noEmit",
    "lint:fix": "biome check --apply .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "i18n": "pnpm i18n:extract && pnpm i18n:compile",
    "release": "git-cliff -o CHANGELOG.md",
    "issues:gen": "pnpx @elcoosp-ai/seedling gen",
    "issues:sync": "pnpx @elcoosp-ai/seedling sync --repo elcoosp/skilldeck --dir ./docs/issues"
  },
