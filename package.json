{
  "name": "skilldeck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "lingui compile && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "i18n": "pnpm i18n:extract && pnpm i18n:compile",
    "issues:gen": "pnpx @elcoosp-ai/seedling gen",
    "issues:sync": "pnpx @elcoosp-ai/seedling sync --repo elcoosp/skilldeck --dir ./docs/issues",
    "release": "git-cliff -o CHANGELOG.md"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@lingui/core": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-diff-viewer": "^3.1.1",
    "react-dom": "^19.1.0",
    "react-focus-lock": "^2.13.7",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.2",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.3",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@elcoosp-configs/lefthook": "^0.0.9",
    "@lingui/cli": "^5.9.2",
    "@lingui/conf": "^5.9.2",
    "@lingui/macro": "^5.9.2",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/ui": "^4.0.18",
    "cspell": "^9.7.0",
    "git-cliff": "^2.12.0",
    "lefthook": "^2.1.4",
