{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillDeck",
  "version": "0.1.0",
  "identifier": "com.skilldeck.core",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "title": "SkillDeck",
        "width": 400,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": true,
        "url": "/splashscreen.html"
      },
      {
        "title": "SkillDeck",
        "width": 1200,
        "height": 800,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
