{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillDeck",
  "version": "0.1.0",
  "identifier": "com.skilldeck.core",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillDeck",
        "width": 1200,
        "height": 800,
        "visible": true,
        "center": true,
        "resizable": true,
        "dragDropEnabled": true,
        "fullscreen": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "additionalBrowserArgs": "--remote-debugging-port=9222"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "skilldeck"
        ]
      },
      "mobile": [
        {
          "scheme": [
            "skilldeck"
          ],
          "appLink": false
        }
      ]
    }
  }
}
